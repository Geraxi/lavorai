# --- Sprint 2: pipeline AI ---
ANTHROPIC_API_KEY=
RESEND_API_KEY=
RESEND_FROM_OVERRIDE=

# --- Sprint 4: auto-apply ---

# Adzuna Jobs API — https://developer.adzuna.com (registrazione gratis)
# Senza queste chiavi, il feed /jobs usa 10 job mock per sviluppo.
ADZUNA_APP_ID=
ADZUNA_APP_KEY=

# Chiave di cifratura per session cookie dei portali terzi.
# ALMENO 32 caratteri, random. Genera con: openssl rand -hex 32
# In produzione: metti su Vercel env + ruota annualmente.
APP_ENCRYPTION_KEY=

# Prisma — SQLite locale (default). Per prod: Supabase Frankfurt postgresql
DATABASE_URL="file:./dev.db"

# --- Stripe (sprint 5) ---
STRIPE_SECRET_KEY=
STRIPE_PAYMENT_LINK=https://buy.stripe.com/test_XXX
STRIPE_WEBHOOK_SECRET=

# --- App ---
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_STRIPE_PAYMENT_LINK=https://buy.stripe.com/test_XXX
